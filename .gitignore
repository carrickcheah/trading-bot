# ---------------------------------------------------------------
# Secrets — never commit. Every entry below blocks a public-repo
# credential leak. Add to this list, never remove.
# ---------------------------------------------------------------
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.crt
*.p12
*.pfx
credentials.json
service-account*.json

# IBKR / broker artifacts that may contain account info
ibkr_creds*
tws_creds*
*.tws
jts.ini

# Local infra references (shared VM access — never commit)
infra/SHARED.md
infra/ssh_key
infra/ssh_key.pub
infra/azure-credentials.json
infra/*.pem
infra/.env*

# ---------------------------------------------------------------
