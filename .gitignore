# ---------------------------------------------------------------
build/
build-*/
out/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
Makefile
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.app
*.exp
*.pdb
*.ilk
*.idb
compile_commands.json

# Test/coverage output
*.gcno
*.gcda
*.gcov
coverage/
*.profraw
*.profdata
Testing/
CTestTestfile.cmake

